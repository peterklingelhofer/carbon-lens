{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus scraping the CarbonLens /metrics endpoint",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "CarbonLens — Grid Carbon",
  "uid": "carbonlens-grid-carbon",
  "tags": ["carbon", "sustainability", "carbonlens"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "5m",
  "templating": {
    "list": [
      {
        "name": "zone",
        "label": "Grid zone",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(carbon_intensity_gco2_kwh, grid_zone)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Greenest region right now",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 150 },
              { "color": "orange", "value": 300 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "min(carbon_intensity_gco2_kwh)",
          "legendFormat": "min gCO2/kWh"
        }
      ]
    },
    {
      "id": 2,
      "title": "Carbon intensity by zone (gCO2/kWh)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 16, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "drawStyle": "line" } } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "carbon_intensity_gco2_kwh{grid_zone=~\"$zone\"}",
          "legendFormat": "{{grid_zone}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Current carbon intensity by region",
      "type": "table",
      "gridPos": { "h": 10, "w": 8, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "sortBy": [{ "displayName": "Value", "desc": false }] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "carbon_intensity_gco2_kwh{grid_zone=~\"$zone\"}",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Renewable share by zone (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 10 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "carbon_renewable_percentage{grid_zone=~\"$zone\"}",
          "legendFormat": "{{grid_zone}}"
        }
      ]
    }
  ]
}
