# Copy to secrets.yaml and fill in real values.
# secrets.yaml is gitignored — never commit real credentials.
#
# Used by helmfile: `helmfile -e production apply`

carbonProviders:
  eiaApiKey: "your-eia-api-key"
  gridStatusApiKey: "your-gridstatus-api-key"
  entsoeToken: "your-entsoe-token"
  electricityMapsApiKey: ""

stripe:
  secretKey: "sk_live_..."
  webhookSecret: "whsec_..."
  priceIdPro: "price_..."
  priceIdEnterprise: "price_..."

config:
  adminSecret: "your-admin-secret"

database:
  url: "postgresql+asyncpg://user:pass@your-managed-db:5432/carbon_mesh"
