# CarbonLens — Environment Configuration
# Copy to .env and fill in your API keys

# Carbon data source: "hybrid" (recommended), "mock", "eia", "gridstatus", "electricity_maps"
# "hybrid" cascades: UK → EIA → AEMO → Grid India → ONS Brazil → Eskom → GridStatus → ENTSO-E → Open-Meteo → Mock
CARBON_LENS_CARBON_SOURCE=hybrid

# EIA API (free — https://www.eia.gov/opendata/)
CARBON_LENS_EIA_API_KEY=

# GridStatus.io (free tier — https://www.gridstatus.io/)
CARBON_LENS_GRID_STATUS_API_KEY=

# ENTSO-E Transparency Platform (free token — https://transparency.entsoe.eu/)
CARBON_LENS_ENTSOE_TOKEN=

# Electricity Maps (optional, paid — https://api-portal.electricitymaps.com/)
CARBON_LENS_ELECTRICITY_MAPS_API_KEY=

# Cache TTL in seconds (default: 300 = 5 minutes)
CARBON_LENS_CACHE_TTL_SECONDS=300

# Published snapshot the scheduler reads current intensity from (one cached fetch
# of all zones) instead of live-fetching dozens per request. Defaults to the
# project's published snapshot; set "" to disable and always fetch live.
# CARBON_LENS_SNAPSHOT_URL=https://raw.githubusercontent.com/peterklingelhofer/carbon-lens/data/snapshot.json

# Server
CARBON_LENS_HOST=0.0.0.0
CARBON_LENS_PORT=8000

# CORS origins (comma-separated in env, or JSON list)
CARBON_LENS_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# PostgreSQL — set USE_DATABASE=true to enable persistence
CARBON_LENS_USE_DATABASE=false
CARBON_LENS_DATABASE_URL=postgresql+asyncpg://carbon_mesh:carbon_mesh@localhost:5432/carbon_mesh

# Auth — set to true to require API keys on all routes
CARBON_LENS_API_KEY_REQUIRED=false

# Admin secret — required for /api/v1/admin/* endpoints (API key management)
CARBON_LENS_ADMIN_SECRET=

# Rate limiting
CARBON_LENS_RATE_LIMIT_DEFAULT=100/minute
CARBON_LENS_RATE_LIMIT_ROUTE=30/minute

# Logging — "text" for dev, "json" for production (Datadog, ELK, CloudWatch)
CARBON_LENS_LOG_FORMAT=text
CARBON_LENS_LOG_LEVEL=INFO

# Startup — auto-run Alembic migrations (recommended for PaaS deploys)
CARBON_LENS_AUTO_MIGRATE=false

# Request limits — max body size in bytes (default: 1 MB)
CARBON_LENS_MAX_REQUEST_BODY_BYTES=1048576

# Stripe billing (optional — leave empty to disable)
# Get keys at https://dashboard.stripe.com/apikeys
CARBON_LENS_STRIPE_SECRET_KEY=
CARBON_LENS_STRIPE_WEBHOOK_SECRET=
CARBON_LENS_STRIPE_PRICE_ID_PRO=
CARBON_LENS_STRIPE_PRICE_ID_ENTERPRISE=
